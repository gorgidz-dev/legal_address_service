# Prod-окружение. Скопируй в .env.production и подставь реальные значения.
# Все обязательные пункты прописаны в docs/security-checklist.md.
# Backend упадёт при старте, если APP_ENV=production и не задан хотя бы один
# из критичных параметров (см. _enforce_production_hardening в app/config.py).

# --- Режим ---
APP_ENV=production

# --- БД ---
POSTGRES_USER=legal_address
POSTGRES_PASSWORD=__сильный_пароль__
POSTGRES_DB=legal_address
# DATABASE_URL подставляется docker-compose автоматически.

# --- Cookies / сессии ---
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_DOMAIN=.uradres.net

# --- Webhook платёжки (HMAC-SHA256, ≥32 байт) ---
# Обязателен даже при ручных платежах (валидатор требует). Сгенерировать:
#   openssl rand -hex 32
PAYMENT_WEBHOOK_SECRET=__random_min_32_bytes__

# --- DaData (https://dadata.ru/profile/) — используется и для геокодинга ---
DADATA_TOKEN=__боевой_токен__
DADATA_SECRET=__боевой_секрет__

# --- SMTP (исходящие письма) ---
# Пусто → письма пишутся в лог (не отправляются). Для боевого — заполнить.
# Пример Yandex 360: host=smtp.yandex.ru port=465 use_ssl=true,
#   username=noreply@uradres.net, password=пароль приложения.
# Пример STARTTLS: port=587, SMTP_USE_TLS=true, SMTP_USE_SSL=false.
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=Uradres <noreply@uradres.net>
SMTP_USE_TLS=false
SMTP_USE_SSL=true

# --- S3 / Object Storage (Selectel) ---
# Панель Selectel → Облачное хранилище → создать приватный контейнер +
# сервисный пользователь S3. Endpoint зависит от пула (ru-1 / gis-1 и т.д.).
STORAGE_BACKEND=s3
S3_ENDPOINT=https://s3.ru-1.storage.selcloud.ru
S3_ACCESS_KEY=__selectel_access_key__
S3_SECRET_KEY=__selectel_secret_key__
S3_BUCKET=uradres-prod
S3_REGION=ru-1

# --- Web Push (VAPID) — сгенерировать: python scripts/gen_vapid_keys.py ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_PEM=
VAPID_SUBJECT=mailto:ops@uradres.net

# --- CDEK Pay (СБП) — MVP: ПУСТО → приём СБП выключен (503), платим вручную ---
# Заполнить боевыми ключами, когда подключим автоматический приём.
CDEK_LOGIN=
CDEK_SECRET_KEY=
CDEK_BASE_URL=https://secure.cdekfin.ru
CDEK_CURRENCY=RUR
CDEK_RETURN_SUCCESS_URL=https://uradres.net/payment/success
CDEK_RETURN_FAIL_URL=https://uradres.net/payment/fail

# --- Caddy (TLS / Let's Encrypt) ---
ACME_EMAIL=ops@uradres.net

# --- Фронт build-args (передаются в frontend/Dockerfile) ---
VITE_YANDEX_MAPS_KEY=__js_api_key__

# --- Прочее ---
DB_ECHO=false
