# Caddy: авто-HTTPS (Let's Encrypt) для uradres.market.
# Терминирует TLS, проксирует на frontend:8080 (nginx со SPA + реверс-прокси
# на backend для /api и /ws). www → редирект на апекс.

{
	email {$ACME_EMAIL}
}

# www → апекс (301).
www.uradres.market {
	redir https://uradres.market{uri} permanent
}

uradres.market {
	encode gzip zstd

	# X-Forwarded-Proto=https прокидывается автоматически — бэкенд это видит
	# (uvicorn --proxy-headers) и помечает Secure-куки корректно.
	reverse_proxy frontend:8080

	# Заголовки безопасности на уровне Caddy (дублируют nginx как fallback).
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://api-maps.yandex.ru https://*.maps.yandex.net https://yastatic.net; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' https: wss:; frame-ancestors 'none'; base-uri 'self'; object-src 'none'"
		-Server
	}

	log {
		output stdout
		format console
	}
}
