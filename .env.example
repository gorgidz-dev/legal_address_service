# Скопируй в .env и заполни.
# Файл .env читается автоматически (см. app/config.py).

# --- БД ---
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/legal_address

# --- DaData (https://dadata.ru/profile/) ---
# Бесплатный тариф: 10 000 запросов/день. Хватает с большим запасом.
# DADATA_TOKEN=your_token_here
# DADATA_SECRET=your_secret_here

# --- S3 / MinIO для файлов выписок и сгенерированных документов ---
# STORAGE_BACKEND=local  # local или s3
# S3_ENDPOINT=https://storage.yandexcloud.net
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=legal-address
# S3_REGION=ru-central1

# --- Доступ ---
# SESSION_COOKIE_NAME=legal_address_session
# WEB_SESSION_TTL_HOURS=24
# MOBILE_SESSION_TTL_HOURS=168
# INVITATION_TTL_HOURS=168

# --- Cookie security (production) ---
# SESSION_COOKIE_SECURE=true              # HTTPS only
# SESSION_COOKIE_SAMESITE=lax             # lax | strict | none (none -> требует secure=true)
# SESSION_COOKIE_DOMAIN=.example.com      # для кросс-поддоменов
