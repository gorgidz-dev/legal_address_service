# Frontend (Vite) environment. Скопируй в frontend/.env и подставь значения.

# Базовый префикс API. По умолчанию /api/v1 (проксируется на бэкенд).
# VITE_API_BASE=/api/v1

# Яндекс.Карты JavaScript API key — для карты адресов в каталоге.
# Получить: https://developer.tech.yandex.ru/services/ → «JavaScript API и Geocoder».
# Пустой ключ → кнопка «На карте» открывается, но карта показывает заглушку.
# VITE_YANDEX_MAPS_KEY=your_jsapi_key_here
